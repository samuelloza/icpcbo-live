#!/bin/sh
# shellcheck shell=sh

# Custom initramfs: finds contest squashfs on any media and mounts root as
# overlay(lower=squashfs, upper=disk-or-tmpfs).
#
# On first ISO boot: copies contest files to a local partition (auto-install).
# Supports ext4/xfs/ext3 (native overlayfs) and NTFS (via overlay.img).

local_top() {
    if [ "${local_top_used:-no}" != "yes" ]; then
        run_scripts /scripts/local-top
    fi
    local_top_used=yes
}

local_premount() {
    if [ "${local_premount_used:-no}" != "yes" ]; then
        run_scripts /scripts/local-premount
    fi
    local_premount_used=yes
}

_log() {
    echo "I: $*" >&2
}

_warn() {
    echo "W: $*" >&2
}

show_boot_banner() {
    local banner="/etc/contest/ascii-wallpaper.txt"

    [ -f "${banner}" ] || return 0

    echo "" >&2
    cat "${banner}" >&2 || true
    echo "" >&2
}

parse_contest_cmdline() {
    CONTEST_DIR="/contest"
    CONTEST_ROOT="filesystem.squashfs"
    CONTEST_PERSIST="auto"
    CONTEST_PERSIST_SCOPE="all"
    CONTEST_INSTALL_MODE="auto"
    CONTEST_CLEAN_INSTALL="0"
    CONTEST_REINSTALL="0"
    CONTEST_RESET_HOME="0"
    CONTEST_RESET_PERSIST="0"
    CONTEST_BOOT_SOURCE="auto"
    CONTEST_MIN_RAM_MB="4096"

    for arg in $(cat /proc/cmdline); do
        case "${arg}" in
            contest_dir=*)          CONTEST_DIR="${arg#contest_dir=}" ;;
            contest_root=*)         CONTEST_ROOT="${arg#contest_root=}" ;;
            contest_persist=*)      CONTEST_PERSIST="${arg#contest_persist=}" ;;
            contest.persist_scope=*) CONTEST_PERSIST_SCOPE="${arg#contest.persist_scope=}" ;;
            contest.install_mode=*) CONTEST_INSTALL_MODE="${arg#contest.install_mode=}" ;;
            contest.clean_install=*) CONTEST_CLEAN_INSTALL="${arg#contest.clean_install=}" ;;
            contest.reinstall=*)    CONTEST_REINSTALL="${arg#contest.reinstall=}" ;;
            contest.reset_home=*)   CONTEST_RESET_HOME="${arg#contest.reset_home=}" ;;
            contest.reset_persist=*) CONTEST_RESET_PERSIST="${arg#contest.reset_persist=}" ;;
            contest.boot_source=*)  CONTEST_BOOT_SOURCE="${arg#contest.boot_source=}" ;;
            contest_min_ram_mb=*)   CONTEST_MIN_RAM_MB="${arg#contest_min_ram_mb=}" ;;
        esac
    done

    case "${CONTEST_DIR}" in
        /*) ;;
        *) CONTEST_DIR="/${CONTEST_DIR}" ;;
    esac
}

cmdline_flag_enabled() {
    case "${1:-0}" in
        1|true|yes|on) return 0 ;;
        *) return 1 ;;
    esac
}

force_reboot() {
    local reason="${1:-requested}"

    if [ "${CONTEST_TEST_NO_REBOOT:-0}" = "1" ]; then
        CONTEST_TEST_REBOOT_REASON="${reason}"
        export CONTEST_TEST_REBOOT_REASON
        return 0
    fi

    reboot -f
    sleep 2
    echo b > /proc/sysrq-trigger 2>/dev/null || true
}

wait_for_reboot_key() {
    local key_dev="${CONTEST_TEST_KEY_DEV:-/dev/console}"
    local old_state=""

    [ -z "${CONTEST_TEST_KEY_DEV:-}" ] && [ -r /dev/tty ] && key_dev="/dev/tty"

    echo "  Presiona una tecla para reiniciar..." >&2
    if command -v stty >/dev/null 2>&1 && command -v dd >/dev/null 2>&1; then
        old_state="$(stty -g < "${key_dev}" 2>/dev/null || true)"
        if [ -n "${old_state}" ] && stty raw -echo < "${key_dev}" 2>/dev/null; then
            dd bs=1 count=1 of=/dev/null < "${key_dev}" 2>/dev/null || true
            stty "${old_state}" < "${key_dev}" 2>/dev/null || true
            force_reboot "key"
            return 0
        fi
        [ -n "${old_state}" ] && stty "${old_state}" < "${key_dev}" 2>/dev/null || true
    fi

    echo "  Presiona ENTER para reiniciar..." >&2
    read -r _ < "${key_dev}" 2>/dev/null || true
    force_reboot "enter"
}

reboot_after_delay() {
    local seconds="${1:-5}"

    if [ "${CONTEST_TEST_NO_REBOOT:-0}" = "1" ]; then
        CONTEST_TEST_REBOOT_REASON="delayed"
        CONTEST_TEST_REBOOT_DELAY="${seconds}"
        export CONTEST_TEST_REBOOT_REASON CONTEST_TEST_REBOOT_DELAY
        return 0
    fi

    echo "  Reiniciando en ${seconds} segundos..." >&2
    sleep "${seconds}"
    force_reboot "delayed"
}

cleanup_message_and_reboot() {
    local title="$1"
    shift

    echo "" >&2
    echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!" >&2
    echo "  ${title}" >&2
    echo "" >&2
    while [ "$#" -gt 0 ]; do
        echo "  $1" >&2
        shift
    done
    echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!" >&2
    echo "" >&2
    wait_for_reboot_key
}

install_complete_message_and_reboot() {
    local install_dev="$1"

    echo "" >&2
    echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!" >&2
    echo "  INSTALACION COMPLETA" >&2
    echo "" >&2
    echo "  Los archivos fueron copiados correctamente a ${install_dev}." >&2
    echo "  El sistema se reiniciara para arrancar desde la instalacion" >&2
    echo "  persistente en el siguiente inicio." >&2
    echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!" >&2
    echo "" >&2
    reboot_after_delay 5
}

clear_dir_contents() {
    local dir="$1"
    local path

    [ -d "${dir}" ] || return 0

    for path in "${dir}"/* "${dir}"/.[!.]* "${dir}"/..?*; do
        [ -e "${path}" ] || continue
        rm -rf "${path}" || return 1
    done
}

clear_dir_except_home() {
    local dir="$1"
    local path base

    [ -d "${dir}" ] || return 0

    for path in "${dir}"/* "${dir}"/.[!.]* "${dir}"/..?*; do
        [ -e "${path}" ] || continue
        base="${path##*/}"
        [ "${base}" = "home" ] && continue
        rm -rf "${path}" || return 1
    done
}

apply_persistence_actions() {
    [ -n "${PERSIST_DATA_DIR:-}" ] || return 0
    [ -n "${PERSIST_META_DIR:-}" ] || return 0

    mkdir -p "${PERSIST_DATA_DIR}" "${PERSIST_META_DIR}" || \
        panic "No se pudo preparar el directorio de persistencia"

    if cmdline_flag_enabled "${CONTEST_RESET_PERSIST}"; then
        _log "Borrando persistencia almacenada..."
        clear_dir_contents "${PERSIST_DATA_DIR}" || panic "No se pudo borrar la persistencia"
        clear_dir_contents "${PERSIST_META_DIR}" || panic "No se pudo limpiar metadatos de persistencia"
    elif cmdline_flag_enabled "${CONTEST_RESET_HOME}"; then
        _log "Limpiando /home persistido..."
        rm -rf "${PERSIST_DATA_DIR}/home" || panic "No se pudo limpiar /home persistido"
        clear_dir_contents "${PERSIST_META_DIR}" || panic "No se pudo limpiar metadatos de persistencia"
    fi

    case "${CONTEST_PERSIST_SCOPE}" in
        home)
            _log "Conservando solo /home en la persistencia."
            clear_dir_except_home "${PERSIST_DATA_DIR}" || panic "No se pudo limitar la persistencia a /home"
            clear_dir_contents "${PERSIST_META_DIR}" || panic "No se pudo reiniciar metadatos de persistencia"
            ;;
    esac
}

collect_unique_block_candidates() {
    local candidates="$1"
    local skip_dev="${2:-}"
    local dev real

    : > "${candidates}"

    for dev in /dev/disk/by-uuid/* /dev/nvme*n*p* /dev/sd*[0-9] /dev/vd*[0-9] /dev/mmcblk*p*; do
        [ -e "${dev}" ] || continue
        real="$(readlink -f "${dev}" 2>/dev/null || echo "${dev}")"
        [ -b "${real}" ] || continue
        [ -n "${skip_dev}" ] && [ "${real}" = "${skip_dev}" ] && continue
        grep -qx "${real}" "${candidates}" 2>/dev/null && continue
        echo "${real}" >> "${candidates}"
    done
}

portable_install_present_at() {
    local mount_root="$1"
    local install_root="${mount_root}${CONTEST_DIR}"

    [ -d "${install_root}" ] || return 1
    [ -f "${install_root}/vmlinuz" ] || return 1
    [ -f "${install_root}/initrd.img" ] || return 1
    [ -f "${install_root}/${CONTEST_ROOT}" ] || return 1
}

remove_portable_install_at() {
    local mount_root="$1"
    local install_root="${mount_root}${CONTEST_DIR}"

    portable_install_present_at "${mount_root}" || return 1
    rm -rf "${install_root}"
}

format_ext4_overlay_image() {
    local overlay_img="$1"

    if [ -n "${CONTEST_EXT4_FORMATTER:-}" ]; then
        "${CONTEST_EXT4_FORMATTER}" -q -F -t ext4 -E nodiscard,lazy_itable_init=0,lazy_journal_init=0 -L contest-overlay "${overlay_img}" >/dev/null 2>&1 && return 0
        "${CONTEST_EXT4_FORMATTER}" -F -L contest-overlay "${overlay_img}" >/dev/null 2>&1
        return $?
    fi

    if [ -x /usr/lib/contest-initramfs/bin/mke2fs.real ]; then
        /usr/lib/contest-initramfs/bin/mke2fs.real -q -F -t ext4 -E nodiscard,lazy_itable_init=0,lazy_journal_init=0 -L contest-overlay "${overlay_img}" >/dev/null 2>&1
        return $?
    fi

    if [ -x /usr/sbin/mke2fs ]; then
        /usr/sbin/mke2fs -q -F -t ext4 -E nodiscard,lazy_itable_init=0,lazy_journal_init=0 -L contest-overlay "${overlay_img}" >/dev/null 2>&1 && return 0
        /usr/sbin/mke2fs -F -L contest-overlay "${overlay_img}" >/dev/null 2>&1
        return $?
    fi

    if [ -x /sbin/mke2fs ]; then
        /sbin/mke2fs -q -F -t ext4 -E nodiscard,lazy_itable_init=0,lazy_journal_init=0 -L contest-overlay "${overlay_img}" >/dev/null 2>&1 && return 0
        /sbin/mke2fs -F -L contest-overlay "${overlay_img}" >/dev/null 2>&1
        return $?
    fi

    if command -v mke2fs >/dev/null 2>&1; then
        mke2fs -q -F -t ext4 -E nodiscard,lazy_itable_init=0,lazy_journal_init=0 -L contest-overlay "${overlay_img}" >/dev/null 2>&1 && return 0
        mke2fs -F -L contest-overlay "${overlay_img}" >/dev/null 2>&1
        return $?
    fi

    return 127
}

ext4_overlay_formatter_available() {
    [ -n "${CONTEST_EXT4_FORMATTER:-}" ] && return 0
    [ -x /usr/lib/contest-initramfs/bin/mke2fs.real ] && return 0
    [ -x /usr/sbin/mke2fs ] && return 0
    [ -x /sbin/mke2fs ] && return 0
    command -v mke2fs >/dev/null 2>&1 && return 0
    return 1
}

check_min_ram() {
    [ -n "${CONTEST_MIN_RAM_MB:-}" ] || return 0

    local total_kb total_mb
    total_kb=$(awk '/MemTotal:/ {print $2; exit}' /proc/meminfo 2>/dev/null)
    [ -n "${total_kb:-}" ] || return 0

    total_mb=$(( total_kb / 1024 ))
    if [ "${total_mb}" -lt "${CONTEST_MIN_RAM_MB}" ]; then
        echo "" >&2
        echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!" >&2
        echo "  RAM INSUFICIENTE PARA ICPC BOLIVIA" >&2
        echo "" >&2
        echo "  Detectada: ${total_mb} MB" >&2
        echo "  Requerida: ${CONTEST_MIN_RAM_MB} MB" >&2
        echo "" >&2
        echo "  Presiona ENTER para reiniciar..." >&2
        read -r _ < /dev/console
        force_reboot "low-ram"
    fi
}

mount_opts_for_initramfs_fstype() {
    local fstype="$1"
    local mode="$2"

    case "${fstype}" in
        ntfs) echo "${mode},nls=utf8" ;;
        *) echo "${mode}" ;;
    esac
}

probe_media_with_fstype() {
    local dev="$1" fstype="$2"
    mount -t "${fstype}" -o ro "${dev}" /run/contest-scan 2>/dev/null || return 1
    if [ -f "/run/contest-scan${CONTEST_DIR}/${CONTEST_ROOT}" ]; then
        FOUND_DEV="${dev}"
        FOUND_FSTYPE="${fstype}"
        umount /run/contest-scan
        return 0
    fi
    umount /run/contest-scan
    return 1
}

find_contest_media() {
    mkdir -p /run/contest-scan
    local candidates="/run/contest-candidates"
    local dev
    : > "${candidates}"

    for dev in /dev/disk/by-uuid/* /dev/disk/by-label/* \
               /dev/nvme*n*p* /dev/sd*[0-9] /dev/vd*[0-9] /dev/mmcblk*p* /dev/sr0; do
        [ -e "${dev}" ] || continue
        local real
        real="$(readlink -f "${dev}" 2>/dev/null || echo "${dev}")"
        [ -b "${real}" ] || continue
        grep -qx "${real}" "${candidates}" 2>/dev/null || echo "${real}" >> "${candidates}"
    done

    _log "Buscando medio con sistema contest..."

    if [ "${CONTEST_BOOT_SOURCE}" = "iso" ]; then
        while read -r dev; do
            if probe_media_with_fstype "${dev}" iso9660; then
                _log "Medio encontrado: ${dev} (iso9660)"
                rm -f "${candidates}"
                return 0
            fi
        done < "${candidates}"
    fi

    while read -r dev; do
        for fstype in iso9660 ext4 ext3 ext2 xfs vfat exfat ntfs3; do
            [ "${CONTEST_BOOT_SOURCE}" = "iso" ] && [ "${fstype}" = "iso9660" ] && continue
            if probe_media_with_fstype "${dev}" "${fstype}"; then
                _log "Medio encontrado: ${dev} (${fstype})"
                rm -f "${candidates}"
                return 0
            fi
        done
    done < "${candidates}"

    rm -f "${candidates}"
    return 1
}

AUTOINSTALL_MIN_FREE_KB=10485760   # 10 GB

_install_error() {
    echo "" >&2
    echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!" >&2
    echo "  ERROR DE INSTALACION PERSISTENTE" >&2
    echo "" >&2
    echo "  $*" >&2
    echo "" >&2
    echo "  El sistema NO se instalo en el disco." >&2
    echo "  Opciones:" >&2
    echo "    - Reinicia y selecciona 'Instalar sistema' (instalacion completa)" >&2
    echo "    - Libera espacio en el disco (se necesitan >= 10 GB)" >&2
    echo "    - Conecta un disco con mas espacio disponible" >&2
    echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!" >&2
    echo "" >&2
    echo "  Presiona ENTER para reiniciar..." >&2
    read -r _ < /dev/console
    force_reboot "install-error"
}

_find_install_target() {
    local source_dev="$1"
    local real free_kb free_gb
    local found_block=0   # disco detectado como dispositivo de bloque
    local found_mount=0   # al menos una particion se pudo montar
    local candidates="/run/contest-install-targets"

    mkdir -p /run/contest-install-probe
    collect_unique_block_candidates "${candidates}" "${source_dev}"

    _log "Buscando particion destino (>= 10 GB libres)..."
    while read -r real; do
        [ -n "${real}" ] || continue
        found_block=1
        _log "  disco detectado: ${real}"

        for fstype in ext4 xfs ext3 ntfs3 ntfs; do
            local mnt_opts
            mnt_opts="$(mount_opts_for_initramfs_fstype "${fstype}" rw)"

            if mount -t "${fstype}" -o "${mnt_opts}" "${real}" /run/contest-install-probe 2>/dev/null; then
                found_mount=1
                free_kb=$(df -k /run/contest-install-probe 2>/dev/null | awk 'NR==2 {print $4}')
                umount /run/contest-install-probe
                if [ "${free_kb:-0}" -ge "${AUTOINSTALL_MIN_FREE_KB}" ]; then
                    free_gb=$(( free_kb / 1024 / 1024 ))
                    _log "  particion destino OK: ${real} (${fstype}, ${free_gb} GB libres)"
                    INSTALL_DEV="${real}"
                    INSTALL_FSTYPE="${fstype}"
                    rm -f "${candidates}"
                    rmdir /run/contest-install-probe 2>/dev/null || true
                    return 0
                else
                    _warn "  ${real} (${fstype}): $(( free_kb / 1024 )) MB libres — necesita >= 10240 MB"
                fi
            fi
        done
    done < "${candidates}"

    rm -f "${candidates}"
    rmdir /run/contest-install-probe 2>/dev/null || true

    if [ "${found_block}" = "0" ]; then
        INSTALL_ERROR="No se detecto ningun disco en el sistema.\nVerifica que el disco este conectado y sea reconocido por el hardware."
    elif [ "${found_mount}" = "0" ]; then
        INSTALL_ERROR="Se detecto un disco pero no se pudo leer ninguna particion.\nEl disco puede estar sin particionar, tener un filesystem no soportado, o estar danado."
    else
        INSTALL_ERROR="Se encontraron particiones pero ninguna tiene espacio suficiente.\nSe necesitan >= 10 GB libres en una sola particion."
    fi
    return 1
}

_scan_disks() {
    # Muestra todos los discos detectados con su espacio disponible.
    # Retorna 0 si hay al menos uno con >= 10 GB, 1 si ninguno sirve.
    local source_dev="$1"
    local real free_kb free_gb total_kb total_gb
    local found_block=0 found_ok=0
    local candidates="/run/contest-disk-candidates"

    echo "" >&2
    echo "  ┌─────────────────────────────────────────────────────┐" >&2
    echo "  │   <()        DISCOS DETECTADOS        <()           │" >&2
    echo "  └─────────────────────────────────────────────────────┘" >&2
    echo "" >&2

    mkdir -p /run/contest-disk-scan
    collect_unique_block_candidates "${candidates}" "${source_dev}"

    while read -r real; do
        [ -n "${real}" ] || continue
        found_block=1

        local mounted=0
        for fstype in ext4 xfs ext3 ntfs3 ntfs vfat exfat; do
            local mnt_opts
            mnt_opts="$(mount_opts_for_initramfs_fstype "${fstype}" rw)"
            if mount -t "${fstype}" -o "${mnt_opts}" "${real}" /run/contest-disk-scan 2>/dev/null; then
                free_kb=$(df -k  /run/contest-disk-scan 2>/dev/null | awk 'NR==2 {print $4}')
                total_kb=$(df -k /run/contest-disk-scan 2>/dev/null | awk 'NR==2 {print $2}')
                umount /run/contest-disk-scan
                free_gb=$(( free_kb  / 1024 / 1024 ))
                total_gb=$(( total_kb / 1024 / 1024 ))
                if [ "${free_kb:-0}" -ge "${AUTOINSTALL_MIN_FREE_KB}" ]; then
                    echo "  [OK] ${real}  (${fstype})  total: ${total_gb} GB  libre: ${free_gb} GB  ← APTO" >&2
                    found_ok=1
                else
                    echo "  [--] ${real}  (${fstype})  total: ${total_gb} GB  libre: ${free_gb} GB  (necesita >= 10 GB)" >&2
                fi
                mounted=1
                break
            fi
        done

        if [ "${mounted}" = "0" ]; then
            echo "  [??] ${real}  no se pudo leer (sin particion o formato no soportado)" >&2
        fi
    done < "${candidates}"

    echo "" >&2
    rm -f "${candidates}"
    rmdir /run/contest-disk-scan 2>/dev/null || true

    if [ "${found_block}" = "0" ]; then
        echo "  No se detecto ningun disco en el sistema." >&2
    fi
    echo "" >&2
    [ "${found_ok}" = "1" ] && return 0
    return 1
}

find_existing_install() {
    local real fstype marker_root
    local candidates="/run/contest-existing-candidates"

    mkdir -p /run/contest-existing-scan
    collect_unique_block_candidates "${candidates}" "${FOUND_DEV}"

    while read -r real; do
        [ -n "${real}" ] || continue
        for fstype in ext4 xfs ext3 ntfs3 ntfs vfat exfat; do
            if mount -t "${fstype}" -o "$(mount_opts_for_initramfs_fstype "${fstype}" ro)" "${real}" /run/contest-existing-scan 2>/dev/null; then
                marker_root="/run/contest-existing-scan${CONTEST_DIR}"
                if { [ -f "${marker_root}/.contest-installed" ] || [ -f "${marker_root}/vmlinuz" ]; } && \
                   [ -f "${marker_root}/vmlinuz" ] && \
                   [ -f "${marker_root}/initrd.img" ] && \
                   [ -f "${marker_root}/${CONTEST_ROOT}" ]; then
                    umount /run/contest-existing-scan 2>/dev/null || true
                    rmdir /run/contest-existing-scan 2>/dev/null || true
                    FOUND_DEV="${real}"
                    FOUND_FSTYPE="${fstype}"
                    case "${fstype}" in
                        ext4|xfs|ext3) CONTEST_PERSIST=on ;;
                        *) CONTEST_PERSIST=auto ;;
                    esac
                    _log "Instalacion portable existente detectada en ${real} — reutilizando."
                    return 0
                fi
                umount /run/contest-existing-scan 2>/dev/null || true
            fi
        done
    done < "${candidates}"

    rm -f "${candidates}"
    rmdir /run/contest-existing-scan 2>/dev/null || true
    return 1
}

find_existing_install_target() {
    local real fstype marker_root
    local candidates="/run/contest-existing-target-candidates"

    mkdir -p /run/contest-existing-scan
    collect_unique_block_candidates "${candidates}" "${FOUND_DEV}"

    while read -r real; do
        [ -n "${real}" ] || continue
        for fstype in ext4 xfs ext3 ntfs3 ntfs vfat exfat; do
            if mount -t "${fstype}" -o "$(mount_opts_for_initramfs_fstype "${fstype}" ro)" "${real}" /run/contest-existing-scan 2>/dev/null; then
                marker_root="/run/contest-existing-scan${CONTEST_DIR}"
                if [ -f "${marker_root}/.contest-installed" ]; then
                    rm -f "${candidates}"
                    umount /run/contest-existing-scan 2>/dev/null || true
                    rmdir /run/contest-existing-scan 2>/dev/null || true
                    INSTALL_DEV="${real}"
                    INSTALL_FSTYPE="${fstype}"
                    return 0
                fi
                umount /run/contest-existing-scan 2>/dev/null || true
            fi
        done
    done < "${candidates}"

    rm -f "${candidates}"
    rmdir /run/contest-existing-scan 2>/dev/null || true
    return 1
}

handle_install_cleanup_request() {
    cmdline_flag_enabled "${CONTEST_CLEAN_INSTALL}" || return 0

    local cleanup_dev cleanup_fstype cleanup_root
    local mnt_opts

    cleanup_dev=""
    cleanup_fstype=""

    if [ "${FOUND_FSTYPE}" = "iso9660" ]; then
        _log "Buscando instalacion portable para borrar..."
        if ! find_existing_install_target; then
            cleanup_message_and_reboot \
                "NO SE ENCONTRO INSTALACION PORTABLE" \
                "No hay archivos de instalacion para borrar."
        fi
        cleanup_dev="${INSTALL_DEV}"
        cleanup_fstype="${INSTALL_FSTYPE}"
    else
        cleanup_dev="${FOUND_DEV}"
        cleanup_fstype="${FOUND_FSTYPE}"
    fi

    mkdir -p /run/contest-cleanup-dst
    mnt_opts="$(mount_opts_for_initramfs_fstype "${cleanup_fstype}" rw)"

    _log "Montando ${cleanup_dev} para borrar archivos de instalacion..."
    if ! mount -t "${cleanup_fstype}" -o "${mnt_opts}" "${cleanup_dev}" /run/contest-cleanup-dst 2>/dev/null; then
        rmdir /run/contest-cleanup-dst 2>/dev/null || true
        cleanup_message_and_reboot \
            "ERROR AL BORRAR INSTALACION" \
            "No se pudo montar ${cleanup_dev} para escritura."
    fi

    cleanup_root="/run/contest-cleanup-dst${CONTEST_DIR}"
    if ! portable_install_present_at /run/contest-cleanup-dst; then
        umount /run/contest-cleanup-dst 2>/dev/null || true
        rmdir /run/contest-cleanup-dst 2>/dev/null || true
        cleanup_message_and_reboot \
            "NO SE ENCONTRO INSTALACION PORTABLE" \
            "No hay archivos de instalacion en ${cleanup_dev}."
    fi

    _log "Borrando ${cleanup_root}..."
    if ! remove_portable_install_at /run/contest-cleanup-dst; then
        umount /run/contest-cleanup-dst 2>/dev/null || true
        rmdir /run/contest-cleanup-dst 2>/dev/null || true
        cleanup_message_and_reboot \
            "ERROR AL BORRAR INSTALACION" \
            "No se pudo eliminar ${CONTEST_DIR} en ${cleanup_dev}."
    fi

    sync
    umount /run/contest-cleanup-dst 2>/dev/null || true
    rmdir /run/contest-cleanup-dst 2>/dev/null || true

    cleanup_message_and_reboot \
        "BORRADO EXITOSO" \
        "Los archivos de instalacion fueron borrados con exito." \
        "El sistema se reiniciara cuando presiones una tecla."
}

auto_install_to_disk() {
    [ "${FOUND_FSTYPE}" = "iso9660" ] || return 0

    # full-install.sh (userspace) maneja la instalacion completa.
    case "${CONTEST_INSTALL_MODE}" in
        full|live) return 0 ;;
    esac

    if [ "${CONTEST_REINSTALL}" = "1" ]; then
        _log "Modo reinstalacion detectado. Buscando instalacion existente..."
        if ! find_existing_install_target; then
            _install_error "No se encontro una instalacion portable existente para reinstalar."
        fi
    else
        if find_existing_install; then
            return 0
        fi

        _log "Verificando discos disponibles antes de instalar..."
        if ! _scan_disks "${FOUND_DEV}"; then
            _install_error "No hay ningun disco para instalar.\nVerifica la lista de discos mostrada arriba."
        fi
        _log "Disco encontrado. Iniciando instalacion..."

        INSTALL_ERROR=""
        if ! _find_install_target "${FOUND_DEV}"; then
            _install_error "${INSTALL_ERROR}"
        fi
    fi

    mkdir -p /run/contest-install-src /run/contest-install-dst

    _log "Montando ISO fuente ${FOUND_DEV}..."
    if ! mount -t iso9660 -o ro "${FOUND_DEV}" /run/contest-install-src 2>/dev/null; then
        _install_error "No se pudo leer el ISO fuente (${FOUND_DEV})."
    fi

    local mnt_opts
    mnt_opts="$(mount_opts_for_initramfs_fstype "${INSTALL_FSTYPE}" rw)"

    _log "Montando destino ${INSTALL_DEV} (${INSTALL_FSTYPE})..."
    if ! mount -t "${INSTALL_FSTYPE}" -o "${mnt_opts}" "${INSTALL_DEV}" /run/contest-install-dst 2>/dev/null; then
        _install_error "No se pudo montar ${INSTALL_DEV} para escritura.\nVerifica que el disco no este protegido contra escritura."
        umount /run/contest-install-src 2>/dev/null || true
    fi

    if [ "${CONTEST_REINSTALL}" = "1" ]; then
        _log "Reinstalando: borrando ${CONTEST_DIR} en ${INSTALL_DEV}..."
        rm -rf "/run/contest-install-dst${CONTEST_DIR:?}"
    fi

    if [ "${CONTEST_REINSTALL}" != "1" ] && [ -f "/run/contest-install-dst${CONTEST_DIR}/.contest-installed" ]; then
        _log "Instalacion previa detectada en ${INSTALL_DEV} — reutilizando."
        umount /run/contest-install-src 2>/dev/null || true
        umount /run/contest-install-dst 2>/dev/null || true
        FOUND_DEV="${INSTALL_DEV}"
        FOUND_FSTYPE="${INSTALL_FSTYPE}"
        case "${INSTALL_FSTYPE}" in
            ext4|xfs|ext3) CONTEST_PERSIST=on ;;
            *) CONTEST_PERSIST=auto ;;
        esac
        return 0
    fi

    mkdir -p "/run/contest-install-dst${CONTEST_DIR}"
    local src="/run/contest-install-src${CONTEST_DIR}"
    local dst="/run/contest-install-dst${CONTEST_DIR}"

    _log "Copiando archivos contest a ${INSTALL_DEV}..."
    for f in vmlinuz initrd.img "${CONTEST_ROOT}"; do
        [ -f "${src}/${f}" ] || continue
        local size_mb
        size_mb=$(( $(stat -c '%s' "${src}/${f}" 2>/dev/null || echo 0) / 1024 / 1024 ))
        _log "  copiando ${f} (${size_mb} MB)..."
        if ! cp "${src}/${f}" "${dst}/${f}.tmp"; then
            rm -f "${dst}/${f}.tmp"
            umount /run/contest-install-src 2>/dev/null || true
            umount /run/contest-install-dst 2>/dev/null || true
            _install_error "No se pudo copiar '${f}' al disco.\nPosible causa: disco lleno o error de escritura en ${INSTALL_DEV}."
        fi
        mv "${dst}/${f}.tmp" "${dst}/${f}"
        _log "  ${f} — OK"
    done

    case "${INSTALL_FSTYPE}" in
        ext4|xfs|ext3) ;;
        *)
            local overlay_img="${dst}/overlay.img"
            local sqfs_kb overlay_mb
            sqfs_kb=$(du -sk "${src}/${CONTEST_ROOT}" 2>/dev/null | awk '{print $1}')
            overlay_mb=$(( (sqfs_kb / 1024) + 4096 ))
            if command -v truncate >/dev/null 2>&1 && ext4_overlay_formatter_available; then
                _log "${INSTALL_FSTYPE} no soporta overlayfs — creando overlay.img (${overlay_mb} MB)..."
                if ! truncate -s "${overlay_mb}M" "${overlay_img}"; then
                    umount /run/contest-install-src 2>/dev/null || true
                    umount /run/contest-install-dst 2>/dev/null || true
                    _install_error "No hay espacio suficiente para crear overlay.img (${overlay_mb} MB) en ${INSTALL_DEV}."
                fi
                if ! format_ext4_overlay_image "${overlay_img}"; then
                    rm -f "${overlay_img}"
                    _warn "No se pudo formatear overlay.img en initramfs — se arrancara en modo temporal y se aprovisionara despues del boot"
                else
                    _log "overlay.img — OK"
                fi
            else
                _warn "mke2fs/mkfs.ext4 no disponible en initramfs — se arrancara en modo temporal y overlay.img se aprovisionara despues del boot"
            fi
            ;;
    esac

    # ── Verificacion de integridad ────────────────────────────────────────────
    _log "Verificando archivos copiados..."
    local verify_ok=1

    for f in vmlinuz initrd.img "${CONTEST_ROOT}"; do
        [ -f "${src}/${f}" ] || continue

        if [ ! -f "${dst}/${f}" ]; then
            _warn "  FALTA: ${dst}/${f}"
            verify_ok=0
            continue
        fi

        local src_size dst_size
        src_size=$(stat -c '%s' "${src}/${f}" 2>/dev/null || echo 0)
        dst_size=$(stat -c '%s' "${dst}/${f}" 2>/dev/null || echo 0)

        if [ "${src_size}" != "${dst_size}" ]; then
            _warn "  TAMANIO INCORRECTO: ${f} (origen=${src_size}B destino=${dst_size}B)"
            verify_ok=0
        else
            _log "  ${f} — tamanio OK ($(( src_size / 1024 / 1024 )) MB)"
        fi
    done

    # Monta el squashfs brevemente para verificar que no este corrupto.
    if [ -f "${dst}/${CONTEST_ROOT}" ]; then
        _log "  Verificando integridad del squashfs..."
        mkdir -p /run/contest-verify-sqfs
        if mount -o ro,loop "${dst}/${CONTEST_ROOT}" /run/contest-verify-sqfs 2>/dev/null; then
            umount /run/contest-verify-sqfs 2>/dev/null || true
            _log "  squashfs montable — OK"
        else
            _warn "  squashfs NO se puede montar — archivo posiblemente corrupto"
            verify_ok=0
        fi
        rmdir /run/contest-verify-sqfs 2>/dev/null || true
    fi

    if [ "${verify_ok}" != "1" ]; then
        rm -f "${dst}/vmlinuz" "${dst}/initrd.img" "${dst}/${CONTEST_ROOT}" "${dst}/overlay.img"
        umount /run/contest-install-src 2>/dev/null || true
        umount /run/contest-install-dst 2>/dev/null || true
        rmdir /run/contest-install-src /run/contest-install-dst 2>/dev/null || true
        _install_error "Verificacion de archivos FALLO — los archivos copiados estan incompletos o corruptos.\nPosible causa: disco lleno a mitad de copia o error de hardware en ${INSTALL_DEV}."
    fi

    _log "Verificacion completa — todos los archivos correctos."
    # ─────────────────────────────────────────────────────────────────────────

    printf 'INSTALLED_FROM=initramfs\nINSTALL_DEV=%s\nINSTALL_FSTYPE=%s\n' \
        "${INSTALL_DEV}" "${INSTALL_FSTYPE}" \
        > "${dst}/.contest-installed"

    umount /run/contest-install-src 2>/dev/null || true
    umount /run/contest-install-dst 2>/dev/null || true
    rmdir /run/contest-install-src /run/contest-install-dst 2>/dev/null || true

    _log "Instalacion completa en ${INSTALL_DEV}. Reiniciando para entrar con persistencia."
    install_complete_message_and_reboot "${INSTALL_DEV}"
    return 0
}

select_overlay_mode() {
    MEDIA_RW=0
    local mnt_rw="rw" mnt_ro="ro"
    case "${FOUND_FSTYPE}" in
        iso9660)
            if mount -t iso9660 -o ro "${FOUND_DEV}" /run/contest-media 2>/dev/null; then
                _log "Montando medio ${FOUND_DEV} (iso9660)..."
                _log "Medio montado solo lectura"
            else
                panic "No se pudo montar ${FOUND_DEV}"
            fi
            ;;
        ntfs|ntfs3)
            mnt_rw="$(mount_opts_for_initramfs_fstype "${FOUND_FSTYPE}" rw)"
            mnt_ro="$(mount_opts_for_initramfs_fstype "${FOUND_FSTYPE}" ro)"
            _log "Montando medio ${FOUND_DEV} (${FOUND_FSTYPE})..."
            if mount -t "${FOUND_FSTYPE}" -o "${mnt_rw}" "${FOUND_DEV}" /run/contest-media 2>/dev/null; then
                MEDIA_RW=1
                _log "Medio montado lectura/escritura"
            elif mount -t "${FOUND_FSTYPE}" -o "${mnt_ro}" "${FOUND_DEV}" /run/contest-media 2>/dev/null; then
                MEDIA_RW=0
                _log "Medio montado solo lectura"
            else
                panic "No se pudo montar ${FOUND_DEV}"
            fi
            ;;
        *)
            _log "Montando medio ${FOUND_DEV} (${FOUND_FSTYPE})..."
            if mount -t "${FOUND_FSTYPE}" -o "${mnt_rw}" "${FOUND_DEV}" /run/contest-media 2>/dev/null; then
                MEDIA_RW=1
                _log "Medio montado lectura/escritura"
            elif mount -t "${FOUND_FSTYPE}" -o "${mnt_ro}" "${FOUND_DEV}" /run/contest-media 2>/dev/null; then
                MEDIA_RW=0
                _log "Medio montado solo lectura"
            else
                panic "No se pudo montar ${FOUND_DEV}"
            fi
            ;;
    esac

    case "${CONTEST_PERSIST}" in
        off|false|no|0)
            [ "${MEDIA_RW}" = "1" ] && mount -o remount,ro /run/contest-media 2>/dev/null || true
            case "${CONTEST_INSTALL_MODE}" in
                full) _log "Modo instalacion completa — tmpfs temporal para arranque (full-install.sh instalara al disco)" ;;
                *)    _log "Sin persistencia — sesion temporal en tmpfs" ;;
            esac
            _use_tmpfs_overlay
            return 0
            ;;
    esac

    OVERLAY_IMG="/run/contest-media${CONTEST_DIR}/overlay.img"
    if [ "${MEDIA_RW}" = "1" ] && [ -f "${OVERLAY_IMG}" ]; then
        modprobe loop 2>/dev/null || true
        mkdir -p /run/contest-overlay
        _log "Montando overlay.img para persistencia..."
        if mount -o loop "${OVERLAY_IMG}" /run/contest-overlay 2>/dev/null; then
            mkdir -p /run/contest-overlay/upper /run/contest-overlay/work
            PERSIST_DATA_DIR="/run/contest-overlay/upper"
            PERSIST_META_DIR="/run/contest-overlay/work"
            apply_persistence_actions
            _log "overlay.img montado OK"
            return 0
        fi
        panic "overlay.img encontrado pero no se puede montar"
    fi

    USE_PERSIST=0
    case "${CONTEST_PERSIST}" in
        on|true|yes|1) USE_PERSIST=1 ;;
        auto|*)
            case "${FOUND_FSTYPE}" in
                ext4|xfs|ext3) USE_PERSIST=1 ;;
            esac
            ;;
    esac

    if [ "${MEDIA_RW}" = "1" ] && [ "${USE_PERSIST}" = "1" ]; then
        case "${FOUND_FSTYPE}" in
            ext4|xfs|ext3)
                _log "Persistencia nativa en ${FOUND_FSTYPE}"
                mkdir -p "/run/contest-media${CONTEST_DIR}/persistent-data"
                mkdir -p "/run/contest-media${CONTEST_DIR}/persistent-meta"
                PERSIST_DATA_DIR="/run/contest-media${CONTEST_DIR}/persistent-data"
                PERSIST_META_DIR="/run/contest-media${CONTEST_DIR}/persistent-meta"
                apply_persistence_actions
                return 0
                ;;
        esac
    fi

    [ "${MEDIA_RW}" = "1" ] && mount -o remount,ro /run/contest-media 2>/dev/null || true
    _log "Sin soporte de persistencia — usando tmpfs"
    _use_tmpfs_overlay
}

_use_tmpfs_overlay() {
    mount -t tmpfs tmpfs /run/contest-rw || panic "No se pudo montar tmpfs"
    mkdir -p /run/contest-rw/session-data /run/contest-rw/session-meta
    PERSIST_DATA_DIR="/run/contest-rw/session-data"
    PERSIST_META_DIR="/run/contest-rw/session-meta"
}

mount_root_image() {
    local root_image="$1"
    local loop_dev

    [ -f "${root_image}" ] || panic "Root image no encontrado: ${root_image}"

    mkdir -p /run/contest-lower

    if command -v losetup >/dev/null 2>&1; then
        loop_dev="$(losetup -f 2>/dev/null || true)"
        if [ -n "${loop_dev}" ] && losetup -r "${loop_dev}" "${root_image}" 2>/dev/null; then
            ROOT_LOOP_DEV="${loop_dev}"
            mount -t squashfs -o ro "${loop_dev}" /run/contest-lower && return 0
            losetup -d "${loop_dev}" 2>/dev/null || true
            ROOT_LOOP_DEV=""
        fi
    fi

    mount -t squashfs -o ro,loop "${root_image}" /run/contest-lower
}

mountroot() {
    show_boot_banner
    parse_contest_cmdline
    check_min_ram

    local_top

    wait_for_udev 10

    modprobe loop     >/dev/null 2>&1 || true
    modprobe squashfs >/dev/null 2>&1 || true
    modprobe overlay  >/dev/null 2>&1 || true

    if ! find_contest_media; then
        panic "Medio contest no encontrado. Se esperaba ${CONTEST_DIR}/${CONTEST_ROOT}"
    fi

    mkdir -p /run/contest-media /run/contest-lower /run/contest-rw

    handle_install_cleanup_request

    auto_install_to_disk

    select_overlay_mode

    ROOT_LOOP_DEV=""
    ROOT_IMAGE="/run/contest-media${CONTEST_DIR}/${CONTEST_ROOT}"
    _log "Montando squashfs ${ROOT_IMAGE}..."
    if ! mount_root_image "${ROOT_IMAGE}"; then
        panic "No se pudo montar squashfs: ${ROOT_IMAGE}"
    fi

    local_premount

    _log "Montando overlay root..."
    if ! mount -t overlay overlay \
        -o "lowerdir=/run/contest-lower,upperdir=${PERSIST_DATA_DIR},workdir=${PERSIST_META_DIR}" \
        "${rootmnt?}"; then
        panic "No se pudo montar overlay root"
    fi

    for mp in dev proc sys run tmp; do
        [ -d "${rootmnt?}/${mp}" ] || mkdir -p "${rootmnt?}/${mp}"
    done
    chmod 1777 "${rootmnt?}/tmp" 2>/dev/null || true

    _log "Sistema listo."
}

mount_top() {
    local_top
}

mount_premount() {
    local_premount
}

local_bottom() {
    :
}

mount_bottom() {
    :
}
