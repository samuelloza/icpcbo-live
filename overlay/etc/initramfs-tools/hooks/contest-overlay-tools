#!/bin/sh

set -eu

PREREQ=""

prereqs() {
    echo "${PREREQ}"
}

case "${1:-}" in
    prereqs)
        prereqs
        exit 0
        ;;
esac

. /usr/share/initramfs-tools/hook-functions

copy_required_binary() {
    tool="$1"
    tool_path="$(command -v "${tool}" 2>/dev/null || true)"

    if [ -z "${tool_path}" ]; then
        echo "W: contest-overlay-tools: falta el binario requerido: ${tool}" >&2
        exit 1
    fi

    copy_exec "${tool_path}"
}

copy_contest_binary() {
    tool="$1"
    target="$2"
    tool_path="$(command -v "${tool}" 2>/dev/null || true)"

    if [ -z "${tool_path}" ]; then
        echo "W: contest-overlay-tools: falta el binario requerido: ${tool}" >&2
        exit 1
    fi

    copy_exec "${tool_path}" "${target}"
}

# Las instalaciones portables sobre NTFS/vfat/exFAT necesitan estas
# herramientas durante el arranque temprano para que la primera sesión
# posterior a la instalación pueda crear y montar overlay.img.
# Referencia: https://manpages.debian.org/testing/initramfs-tools-core/initramfs-tools.7.en.html
copy_required_binary truncate
copy_contest_binary mke2fs /usr/lib/contest-initramfs/bin/mke2fs.real

if [ -f /etc/mke2fs.conf ]; then
    copy_file config /etc/mke2fs.conf
fi

if [ -f /etc/contest/ascii-wallpaper.txt ]; then
    copy_file config /etc/contest/ascii-wallpaper.txt
fi
