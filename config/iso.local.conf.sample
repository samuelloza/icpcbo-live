#!/usr/bin/env bash

# Copy this file to config/iso.local.conf and set your production values.
# Expose remote/full-install.sh with:
#   docker compose up -d iso-local-conf-viewer
# Then replace REPLACE_WITH_HOST_IP with the host address reachable by the ISO.

FULL_INSTALL_URL="http://localhost:8081/remote/full-install-bootstrap.sh"
# Leave empty during local testing to skip remote installer SHA validation.
FULL_INSTALL_SHA256="8c607364fdb168563e6ec07486725746c82ffb5ff7ae453913c03565fe0f2cc0"
UPDATE_MANIFEST_URL="http://localhost:8081/updates/manifest.json"
UPDATE_CHECK_ON_BOOT="true"
RUNTIME_VERSION="dev"

# Optional local overrides
# DEFAULT_BROWSER_URL="https://global.naquadah.com.br/boca"
# GNOME_INPUT_SOURCES="[('xkb', 'latam'), ('xkb', 'br'), ('xkb', 'us')]"
# MIN_RAM_MB="8192"
